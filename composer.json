{
    "name": "psc-acme/encoder-cart",
    "description": "Package encoder-cart for psc-acme organization",
    "type": "project",
    "license": "MIT",
    "authors": [
        {
            "name": "Philipp Scheit",
            "email": "p.scheit@packagist.com"
        }
    ],
    "autoload": {
        "psr-4": {
            "PscAcme\\EncoderCart\\": "src/"
        }
    },
    "require": {
        "php": ">=8.3",
        "symfony/http-foundation": "^7.0",
        "illuminate/database": "^11.0",
        "symfony/cache": "^7.0",
        "carbon/carbon": "^3.0",
        "psc-acme/loader-order": "^1.0"
    },
    "require-dev": {
        "phpstan/phpstan": "^1.0"
    },
    "minimum-stability": "stable",
    "config": {
        "secure-http": false
    },
    "repositories": {
        "private-packagist": {
            "type": "composer",
            "url": "http://repo.packagist.com.lo/psc-acme/"
        },
        "packagist.org": false
    }
}